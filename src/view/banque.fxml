<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BanqueController" stylesheets="@style.css">
    <!-- Onglet Clients -->
    <Tab text="Clients">
        <VBox spacing="10">
            <GridPane hgap="10" vgap="10">
                <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Prénom :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPrenom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Téléphone :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTelephone" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Email :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtEmail" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Ajouter" onAction="#ajouterClient"/>
                <Button text="Modifier" onAction="#modifierClient"/>
                <Button text="Supprimer" onAction="#supprimerClient"/>
                <TextField fx:id="txtRechercheClient" promptText="Rechercher..."/>
                <Button text="Rechercher" onAction="#rechercherClient"/>
            </HBox>
            <TableView fx:id="tableClients">
                <columns>
                    <TableColumn text="ID" fx:id="colClientId"/>
                    <TableColumn text="Nom" fx:id="colClientNom"/>
                    <TableColumn text="Prénom" fx:id="colClientPrenom"/>
                    <TableColumn text="Téléphone" fx:id="colClientTel"/>
                    <TableColumn text="Email" fx:id="colClientEmail"/>
                </columns>
            </TableView>
        </VBox>
    </Tab>

    <!-- Onglet Comptes -->
    <Tab text="Comptes">
        <VBox spacing="10">
            <GridPane hgap="10" vgap="10">
                <Label text="Numéro compte :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNumeroCompte" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Type :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboTypeCompte" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Solde initial :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtSoldeInitial" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Client :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboClient" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Ajouter" onAction="#ajouterCompte"/>
                <Button text="Modifier" onAction="#modifierCompte"/>
                <Button text="Supprimer" onAction="#supprimerCompte"/>
            </HBox>
            <TableView fx:id="tableComptes">
                <columns>
                    <TableColumn text="ID" fx:id="colCompteId"/>
                    <TableColumn text="Numéro" fx:id="colCompteNumero"/>
                    <TableColumn text="Solde" fx:id="colCompteSolde"/>
                    <TableColumn text="Type" fx:id="colCompteType"/>
                    <TableColumn text="Client ID" fx:id="colCompteIdClient"/>
                </columns>
            </TableView>
        </VBox>
    </Tab>

    <!-- Onglet Opérations -->
    <Tab text="Opérations">
        <VBox spacing="10">
            <Label text="Compte :"/>
            <ComboBox fx:id="comboCompteOperation"/>
            <Label text="Montant :"/>
            <TextField fx:id="txtMontant"/>
            <HBox spacing="10">
                <Button text="Dépôt" onAction="#depot"/>
                <Button text="Retrait" onAction="#retrait"/>
            </HBox>
            <Separator/>
            <Label text="Virement"/>
            <Label text="Compte source :"/>
            <ComboBox fx:id="compteSource"/>
            <Label text="Compte destination :"/>
            <ComboBox fx:id="compteDestination"/>
            <Label text="Montant :"/>
            <TextField fx:id="txtMontantVirement"/>
            <Button text="Effectuer virement" onAction="#virement"/>
            <Separator/>
            <Label text="Historique des opérations"/>
            <TableView fx:id="tableOperations">
                <columns>
                    <TableColumn text="ID" fx:id="colOpId"/>
                    <TableColumn text="Type" fx:id="colOpType"/>
                    <TableColumn text="Montant" fx:id="colOpMontant"/>
                    <TableColumn text="Date" fx:id="colOpDate"/>
                </columns>
            </TableView>
        </VBox>
    </Tab>
</TabPane>